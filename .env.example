# Most users don't need this file. The CLI ships with an embedded client ID and
# uses the 'common' authority endpoint, which works for both personal Microsoft
# accounts and any work/school tenant.
#
# Copy to .env only if you need to override the embedded defaults:
#
# AZURE_CLIENT_ID   — dedicated Entra app instead of the shared Alavida one
# AZURE_TENANT_ID   — pin to a specific tenant instead of 'common'
# OUTLOOK_CLI_TOKEN_CACHE — override the file-fallback cache path (default: ~/.outlook-cli/tokens.json)

# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# OUTLOOK_CLI_TOKEN_CACHE=~/.outlook-cli/tokens.json
